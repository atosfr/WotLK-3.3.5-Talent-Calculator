<UserControl x:Class="WotLK_TalentCalculator_3._3._5.Controls.SmallIconControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="24" Height="24"
             Background="Transparent"
             MouseEnter="OnMouseEnter"
             MouseLeave="OnMouseLeave">
    <Grid>
        <Image x:Name="PART_Icon" Width="18" Height="18" 
               RenderOptions.BitmapScalingMode="NearestNeighbor" 
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Image x:Name="PART_Frame" Width="24" Height="24" 
               RenderOptions.BitmapScalingMode="NearestNeighbor" 
               Stretch="Fill" IsHitTestVisible="False"/>

        <Image x:Name="PART_Highlight" Width="24" Height="24" 
               RenderOptions.BitmapScalingMode="NearestNeighbor" 
               Stretch="Fill" Visibility="Hidden" IsHitTestVisible="False"/>
    </Grid>
</UserControl>