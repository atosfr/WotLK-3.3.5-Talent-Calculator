<UserControl x:Class="WotLK_TalentCalculator_3._3._5.Controls.IconControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WotLK_TalentCalculator_3._3._5.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="44" d:DesignWidth="44"
             ClipToBounds="False"
             Background="Transparent"
             MouseEnter="OnMouseEnter"
             MouseLeave="OnMouseLeave"
             MouseLeftButtonDown="OnLeftClick"
             MouseRightButtonDown="OnRightClick">

    <Grid Width="44" Height="44" ClipToBounds="False" Background="Transparent">

        <Image x:Name="PART_Icon"
               Width="36" Height="36"
               SnapsToDevicePixels="True"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

        <Image x:Name="PART_Highlight"
               Width="38" Height="38"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               Visibility="Hidden"
               IsHitTestVisible="False"/>

        <Image x:Name="PART_Frame"
               Width="44" Height="44"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               IsHitTestVisible="False"/>

        <Image x:Name="PART_StateBorder"
               Width="42" Height="42"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               IsHitTestVisible="False"/>

        <Grid x:Name="PART_Bubble"
              Width="22" Height="23"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,-6,-5"
              Visibility="Hidden"
              ClipToBounds="False">

            <Image x:Name="PART_BubbleImage"
                   Stretch="Fill"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>

            <TextBlock x:Name="PART_RankText"
                       Text="0"
                       FontFamily="Verdana"
                       Foreground="White"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,0,0,1"/>
        </Grid>
    </Grid>
</UserControl>