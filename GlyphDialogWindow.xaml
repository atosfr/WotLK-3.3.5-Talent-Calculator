<Window x:Class="WotLK_TalentCalculator_3._3._5.GlyphDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WotLK_TalentCalculator_3._3._5.Controls"
        Title="Select Glyph" Height="720" Width="640"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!-- Custom dark scrollbar -->
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Background="#FF555566" 
                                       BorderThickness="0">
                                    <Thumb.Style>
                                        <Style TargetType="Thumb">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#FF555566" 
                                                                CornerRadius="4" 
                                                                MinHeight="20"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Thumb.Style>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                               Name="PART_VerticalScrollBar"
                               Style="{StaticResource DarkScrollBar}"
                               Value="{TemplateBinding VerticalOffset}"
                               Maximum="{TemplateBinding ScrollableHeight}"
                               ViewportSize="{TemplateBinding ViewportHeight}"
                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FF1A1A2E" BorderBrush="#FF34495E" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: None + Search -->
            <Border Grid.Row="0" Background="#FF0D0D1A" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="— None —" 
                               Foreground="#FF888899" FontSize="12" 
                               Cursor="Hand" VerticalAlignment="Center"
                               MouseLeftButtonUp="BtnNone_Click">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Arama kutusu -->
                    <Border Grid.Column="2" Background="#FF13132A" 
                            BorderBrush="#FF2A2A45" BorderThickness="1" 
                            Padding="6,3" MinWidth="170">
                        <TextBox x:Name="TxtSearch" 
                                 Background="Transparent" 
                                 Foreground="#FFCCCCDD" 
                                 CaretBrush="White"
                                 BorderThickness="0" 
                                 FontSize="11"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Tag" Value="Search within results..."/>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>
                </Grid>
            </Border>

            <!-- Başlık satırı -->
            <Border Grid.Row="1" Background="#FF0D0D1A" 
                    BorderBrush="#FF2A2A45" BorderThickness="0,1,0,0"
                    Padding="10,5">
                <TextBlock x:Name="TxtTitle" Text="Select Major Glyph" 
                           Foreground="#FFFFD100" FontSize="12" FontWeight="SemiBold"/>
            </Border>

            <!-- Glyph listesi -->
            <ScrollViewer Grid.Row="2" 
                          Style="{StaticResource DarkScrollViewer}"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="GlyphListPanel"/>
            </ScrollViewer>

            <!-- Alt çubuk: CLOSE X -->
            <Border Grid.Row="3" Background="#FF0D0D1A" 
                    BorderBrush="#FF2A2A45" BorderThickness="0,1,0,0"
                    Padding="0,6">
                <TextBlock Text="CLOSE X" 
                           Foreground="#FF888899" FontSize="11" FontWeight="Bold"
                           HorizontalAlignment="Right" 
                           Margin="0,0,12,0"
                           Cursor="Hand"
                           MouseLeftButtonUp="BtnClose_Click2">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>