<Window x:Class="WotLK_TalentCalculator_3._3._5.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WotLK_TalentCalculator_3._3._5"
        xmlns:controls="clr-namespace:WotLK_TalentCalculator_3._3._5.Controls"
        mc:Ignorable="d"
        Title="WotLK Talent Calculator 3.3.5"
        Height="790" Width="720"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg"    Color="#FF13132A"/>
        <SolidColorBrush x:Key="HeaderBg"   Color="#FF09091A"/>
        <SolidColorBrush x:Key="BorderDark" Color="#FF2A2A45"/>
        <SolidColorBrush x:Key="GoldBrush"  Color="#FFFFD100"/>
        <SolidColorBrush x:Key="TextMain"   Color="#FFCCCCDD"/>
        <SolidColorBrush x:Key="TextDim"    Color="#FF888899"/>
        <SolidColorBrush x:Key="ResetRed"   Color="#FFCC3333"/>
        <SolidColorBrush x:Key="AppBorder"  Color="#FF34495E"/>
        <SolidColorBrush x:Key="TitleBarBg" Color="#FF141414"/>

        <Style x:Key="MenuButtonStyle" TargetType="Control">
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="HoverText">
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#FF23313F" BorderBrush="{StaticResource AppBorder}" BorderThickness="2" CornerRadius="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── Title bar ────────────────────────────────────── -->
                <Grid Grid.Row="0" Background="{StaticResource TitleBarBg}" MouseLeftButtonDown="TitleBar_MouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Image x:Name="AppIconImage" Width="16" Height="16" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <TextBlock Text="WotLK Talent Calculator (3.3.5)" Foreground="{StaticResource GoldBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="—" Foreground="White" FontSize="14" FontWeight="Bold" Padding="15,6" Cursor="Hand" Background="Transparent" MouseLeftButtonDown="BtnMinimize_Click">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FF333333"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="✕" Foreground="White" FontSize="14" FontWeight="Bold" Padding="15,6" Cursor="Hand" Background="Transparent" MouseLeftButtonDown="BtnClose_Click">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ResetRed}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- ── Content ──────────────────────────────────────── -->
                <Grid Grid.Row="1" Margin="15,10,15,15" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="Transparent" Padding="15,8,15,12">
                        <StackPanel x:Name="ClassBar" Orientation="Horizontal" HorizontalAlignment="Left"/>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Grid.Row="1" Orientation="Vertical" Width="616">

                            <!-- ── Toolbar ─────────────────────────────── -->
                            <Border Background="{StaticResource HeaderBg}"
                            BorderBrush="{StaticResource BorderDark}"
                            BorderThickness="0,0,0,1"
                            Padding="15,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <!-- LEFT: Profiles button -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- RİGHT: diğer buttons -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: Profiles butonu -->
                                    <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                        <StackPanel x:Name="BtnProfiles"
                                            Orientation="Horizontal"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonUp="BtnProfiles_Click">
                                            <TextBlock Text="▤ " Foreground="{StaticResource GoldBrush}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="Profiles"
                                               Style="{StaticResource HoverText}"
                                               VerticalAlignment="Center"/>
                                            <!-- Saved profile count -->
                                            <TextBlock x:Name="TxtProfileCount"
                                               Foreground="{StaticResource TextDim}"
                                               FontSize="11"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Right: Reset All, Lock, Glyph, Import, Export -->
                                    <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">

                                        <StackPanel x:Name="BtnResetAll" Orientation="Horizontal" Cursor="Hand" Margin="0,0,15,0" Background="Transparent" MouseLeftButtonUp="BtnResetAll_Click">
                                            <Image x:Name="ImgResetAll" Margin="0,0,5,0" Stretch="None"/>
                                            <TextBlock Text="Reset All" Style="{StaticResource HoverText}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel x:Name="BtnLock" Orientation="Horizontal" Cursor="Hand" Margin="0,0,15,0" Background="Transparent" MouseLeftButtonUp="BtnLock_Click">
                                            <Image x:Name="ImgLock" Margin="0,0,5,0" Stretch="None"/>
                                            <TextBlock x:Name="TxtLock" Text="Lock" Style="{StaticResource HoverText}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock x:Name="BtnGlyph" Text="Glyph" Style="{StaticResource HoverText}" Cursor="Hand" Margin="0,0,15,0" VerticalAlignment="Center" MouseLeftButtonUp="BtnGlyph_Click"/>
                                        <TextBlock x:Name="BtnImport" Text="Import" Style="{StaticResource HoverText}" Cursor="Hand" Margin="0,0,15,0" VerticalAlignment="Center" MouseLeftButtonUp="BtnImport_Click"/>
                                        <TextBlock x:Name="BtnExport" Text="Export" Style="{StaticResource HoverText}" Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonUp="BtnExport_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- ── InfoBar ────────────────────────────── -->
                            <Border BorderBrush="{StaticResource BorderDark}"
                                    Background="{StaticResource PanelBg}"
                                    BorderThickness="0,0,0,1"
                                    Padding="14,6"
                                    Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" FontWeight="Bold" FontSize="13" VerticalAlignment="Center">
                                        <Run Text="{Binding InfoVM.ClassName, Mode=OneWay}" Foreground="{Binding InfoVM.ClassBrush, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding InfoVM.DistributionText, Mode=OneWay}" Foreground="White"/>
                                    </TextBlock>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Foreground="#FFDDDDDD" FontSize="12" Text="Required level: "/>
                                        <TextBlock Foreground="White" FontSize="12" Text="{Binding InfoVM.RequiredLevel, Mode=OneWay}"/>
                                        <TextBlock Foreground="White" FontSize="12" Text=" (80)"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" FontSize="13" VerticalAlignment="Center">
                                        <Run Text="Points left: " Foreground="#FFDDDDDD"/>
                                        <Run Text="{Binding InfoVM.PointsLeft, Mode=OneWay}" Foreground="White" FontWeight="Bold"/>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- ── Talent trees ───────────────────────── -->
                            <Border BorderBrush="#FF404040" BorderThickness="1">
                                <Grid Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="204"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="204"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="204"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Image x:Name="Tree1Bg" Width="204" Height="554" Stretch="None" VerticalAlignment="Top"/>
                                        <Canvas x:Name="Tree1Arrows" IsHitTestVisible="False"/>
                                        <Grid x:Name="Tree1Grid" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                        </Grid>
                                    </Grid>

                                    <Rectangle Grid.Column="1" Fill="#FF404040"/>

                                    <Grid Grid.Column="2">
                                        <Image x:Name="Tree2Bg" Width="204" Height="554" Stretch="None" VerticalAlignment="Top"/>
                                        <Canvas x:Name="Tree2Arrows" IsHitTestVisible="False"/>
                                        <Grid x:Name="Tree2Grid" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                        </Grid>
                                    </Grid>

                                    <Rectangle Grid.Column="3" Fill="#FF404040"/>

                                    <Grid Grid.Column="4">
                                        <Image x:Name="Tree3Bg" Width="204" Height="554" Stretch="None" VerticalAlignment="Top"/>
                                        <Canvas x:Name="Tree3Arrows" IsHitTestVisible="False"/>
                                        <Grid x:Name="Tree3Grid" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- ── Footer ────────────────────────────── -->
                            <Border Background="{StaticResource HeaderBg}" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,1,0,0" Padding="0,6" Margin="0,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="204"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="204"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="204"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel x:Name="FooterTree1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    <StackPanel x:Name="FooterTree2" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    <StackPanel x:Name="FooterTree3" Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>

                        </StackPanel>

                        <Border x:Name="GlyphsPanel" Visibility="Collapsed" Width="210" Margin="10,0,0,0" 
                                Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="2">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,15">
                                    <TextBlock Text="Glyphs" Foreground="{StaticResource GoldBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Image x:Name="BtnClearGlyphs" Width="16" Height="16" Cursor="Hand" HorizontalAlignment="Right" ToolTip="Clear all glyphs" Opacity="0.4" 
                                           MouseEnter="BtnClearGlyphs_MouseEnter" MouseLeave="BtnClearGlyphs_MouseLeave" MouseLeftButtonUp="BtnClearGlyphs_Click"/>
                                </Grid>

                                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                                    <TextBlock Text="Major" Foreground="#71d5ff" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <Grid Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="GlyphSlot_Click" MouseRightButtonUp="GlyphSlot_RightClick" MouseEnter="GlyphSlot_MouseEnter" MouseLeave="GlyphSlot_MouseLeave" Tag="Major">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:IconControl x:Name="MajorGlyph1" IsClassIcon="True" IsActive="True" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="TxtMajorGlyph1" Grid.Column="1" Text="Click to select" Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="GlyphSlot_Click" MouseRightButtonUp="GlyphSlot_RightClick" MouseEnter="GlyphSlot_MouseEnter" MouseLeave="GlyphSlot_MouseLeave" Tag="Major">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:IconControl x:Name="MajorGlyph2" IsClassIcon="True" IsActive="True" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="TxtMajorGlyph2" Grid.Column="1" Text="Click to select" Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="GlyphSlot_Click" MouseRightButtonUp="GlyphSlot_RightClick" MouseEnter="GlyphSlot_MouseEnter" MouseLeave="GlyphSlot_MouseLeave" Tag="Major">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:IconControl x:Name="MajorGlyph3" IsClassIcon="True" IsActive="True" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="TxtMajorGlyph3" Grid.Column="1" Text="Click to select" Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Minor" Foreground="#71d5ff" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <Grid Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="GlyphSlot_Click" MouseRightButtonUp="GlyphSlot_RightClick" MouseEnter="GlyphSlot_MouseEnter" MouseLeave="GlyphSlot_MouseLeave" Tag="Minor">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:IconControl x:Name="MinorGlyph1" IsClassIcon="True" IsActive="True" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="TxtMinorGlyph1" Grid.Column="1" Text="Click to select" Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="GlyphSlot_Click" MouseRightButtonUp="GlyphSlot_RightClick" MouseEnter="GlyphSlot_MouseEnter" MouseLeave="GlyphSlot_MouseLeave" Tag="Minor">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:IconControl x:Name="MinorGlyph2" IsClassIcon="True" IsActive="True" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="TxtMinorGlyph2" Grid.Column="1" Text="Click to select" Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="GlyphSlot_Click" MouseRightButtonUp="GlyphSlot_RightClick" MouseEnter="GlyphSlot_MouseEnter" MouseLeave="GlyphSlot_MouseLeave" Tag="Minor">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:IconControl x:Name="MinorGlyph3" IsClassIcon="True" IsActive="True" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="TxtMinorGlyph3" Grid.Column="1" Text="Click to select" Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Popup x:Name="TooltipPopup" Placement="Mouse" AllowsTransparency="True" StaysOpen="True" HorizontalOffset="15" VerticalOffset="15" IsHitTestVisible="False">
            <Grid>
                <controls:TalentTooltipControl x:Name="TalentTooltip" Visibility="Collapsed"/>
                <controls:GlyphTooltipControl x:Name="GlyphTooltip" Visibility="Collapsed"/>
            </Grid>
        </Popup>
    </Grid>
</Window>
